# IANTHE Backend Configuration

# General Server Port
PORT=3001

# JWT Session Encryption Secret (Will be auto-generated during setup if empty)
JWT_SECRET=ac813b8d57cb9f6e3b5718a7665dbb907cc46ce766858ddf914acdc0f189b60b

# Terraform Cloud Settings (Required for CDKTF stacks)
TFC_TOKEN=your_terraform_cloud_token_here
TFC_ORG=your_org_name

# Twilio SMS delivery (Optional: if blank, 2FA SMS codes fall back to warning alerts in developer logs)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# GitHub Social Sign-In (Optional: if blank, triggers a zero-setup local dev mock loop)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google Social Sign-In (Optional: if blank, triggers a zero-setup local dev mock loop)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==================================================================
# CLOUD PROVIDER CREDENTIALS
# (If left blank, the platform automatically runs that provider
# in 'Mock Cloud Mode' using local k3d containers for zero-setup dev)
# ==================================================================

# --- AWS (Amazon Web Services) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# --- GCP (Google Cloud Platform) ---
# GCP_PROJECT=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/gcp-service-account-key.json

# --- Azure (Microsoft Azure) ---
# ARM_CLIENT_ID=
# ARM_CLIENT_SECRET=
# ARM_SUBSCRIPTION_ID=
# ARM_TENANT_ID=

# --- DigitalOcean ---
# DIGITALOCEAN_TOKEN=
